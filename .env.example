# ──────────────────────────────────────────────────────────────
#  CalorieFlow – Environment Variables
#  Copy this file to .env.local and fill in your values
# ──────────────────────────────────────────────────────────────

# ─── Gemini AI (server-side only, never exposed to client) ────
# Get a FREE key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Supabase ─────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# Service role key (server-only, for cron job) – never expose to client
# Supabase Dashboard → Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── Access Control ───────────────────────────────────────────
# Only this email will be allowed to log in.
NEXT_PUBLIC_ALLOWED_EMAIL=your@email.com

# ─── Email (Resend) ───────────────────────────────────────────
# Get a FREE key: https://resend.com
RESEND_API_KEY=re_your_resend_key_here

# ─── Cron Security ────────────────────────────────────────────
# Vercel sets this automatically. For local testing set any secret string.
CRON_SECRET=any_random_secret_here

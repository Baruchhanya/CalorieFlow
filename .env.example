# ──────────────────────────────────────────────────────────────
#  CalorieFlow – Environment Variables
#  Copy this file to .env.local and fill in your values
# ──────────────────────────────────────────────────────────────

# ─── Gemini AI (server-side only, never exposed to client) ────
# Get a FREE key: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Supabase ─────────────────────────────────────────────────
# Get these from: Supabase Dashboard → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# ─── Access Control ───────────────────────────────────────────
# Only this email will be allowed to log in.
# Leave empty to allow any Google account.
NEXT_PUBLIC_ALLOWED_EMAIL=your@email.com
